<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        Odoo 19 removed `numbercall` (crons now run indefinitely) and made
        `nextcall` optional. Mirror the sibling modules' pattern: just name,
        model_id, state, code, interval_*, active, priority.
    -->

    <!--
        Proactive token refresh. The auth service decides whether work is
        actually needed (refreshes only if < 5 min to expiry); the cron
        simply gives it a heartbeat.
    -->
    <record id="cron_refresh_token" model="ir.cron">
        <field name="name">HTF: refresh OAuth token</field>
        <field name="model_id" ref="model_htf_config"/>
        <field name="state">code</field>
        <field name="code">model.cron_refresh_token()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
        <field name="priority">10</field>
    </record>

    <!--
        Idempotency table grows forever otherwise. 90-day window matches
        DATA_MODEL.md §Data Lifecycle.
    -->
    <record id="cron_purge_webhook_events" model="ir.cron">
        <field name="name">HTF: purge old webhook events</field>
        <field name="model_id" ref="model_htf_webhook_event"/>
        <field name="state">code</field>
        <field name="code">model.cron_purge_old(days=90)</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="priority">20</field>
    </record>

    <!--
        P1: nightly channel sync. Picks up new channels Hatif admins
        provisioned during the day and archives the ones removed remotely.
    -->
    <record id="cron_sync_channels_nightly" model="ir.cron">
        <field name="name">HTF: nightly channel sync</field>
        <field name="model_id" ref="model_htf_config"/>
        <field name="state">code</field>
        <field name="code">model.action_sync_channels()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="priority">30</field>
    </record>

    <!--
        P1: contacts poll (placeholder until Hatif exposes an incremental
        delta endpoint, see Q-10 follow-up). Currently a no-op so any
        existing automation depending on the cron survives.
    -->
    <record id="cron_poll_contacts" model="ir.cron">
        <field name="name">HTF: poll contacts (incremental)</field>
        <field name="model_id" ref="model_htf_config"/>
        <field name="state">code</field>
        <field name="code">model.cron_poll_contacts()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <!--
            Active so it shows in the standard Scheduled Actions list and
            ticks every 30 min (currently a no-op until Hatif exposes an
            incremental delta endpoint — see Q-10 follow-up).
        -->
        <field name="active" eval="True"/>
        <field name="priority">40</field>
    </record>

</odoo>
