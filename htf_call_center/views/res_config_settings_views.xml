<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.htf</field>
            <field name="model">res.config.settings</field>
            <field name="priority">90</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//form" position="inside">
                    <!--
                        Odoo 19 Settings left-rail tab is created by the
                        SettingsFormCompiler from each "app" element that
                        carries a name= attribute. Earlier attempts used
                        data-key= (Odoo 17 spelling) which silently fails.
                        IMPORTANT: do NOT include literal angle-bracket
                        markup ("less-than app greater-than") in this
                        comment — the Odoo view loader was re-emitting it
                        as an empty real tag, which broke the compiler.
                    -->
                    <app string="Hatif" name="htf_call_center"
                         logo="/htf_call_center/static/description/icon.png"
                         summary="Hatif/Voxa telephony + WhatsApp integration"
                         groups="base.group_system">
                        <block title="Connection"
                               name="htf_connection_block">
                            <setting id="htf_credentials"
                                     string="Hatif API credentials"
                                     help="Service-account client_id + client_secret issued by the Hatif team.">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="htf_client_id" class="col-lg-3 o_light_label"/>
                                        <field name="htf_client_id"/>
                                    </div>
                                    <div class="row">
                                        <label for="htf_client_secret" class="col-lg-3 o_light_label"/>
                                        <field name="htf_client_secret" password="True"/>
                                    </div>
                                    <div class="row">
                                        <label for="htf_base_url" class="col-lg-3 o_light_label"/>
                                        <field name="htf_base_url"/>
                                    </div>
                                    <div class="row">
                                        <label for="htf_scope" class="col-lg-3 o_light_label"/>
                                        <field name="htf_scope"/>
                                    </div>
                                    <div class="row mt16">
                                        <button name="action_test_connection"
                                                type="object"
                                                string="Test Connection"
                                                class="btn-primary"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="Inbound webhook URLs (give these to Hatif)"
                               name="htf_webhook_urls_block">
                            <setting id="htf_webhook_urls"
                                     string="Webhook endpoints on this Odoo"
                                     help="These are the public URLs this Odoo instance listens on for Hatif post-call and WhatsApp deliveries. They are derived from web.base.url so each environment (dev / staging / prod) shows its own correct URL automatically.">
                                <div class="content-group">
                                    <div class="row">
                                        <label for="htf_webhook_url_call" class="col-lg-3 o_light_label"/>
                                        <field name="htf_webhook_url_call" widget="CopyClipboardChar" readonly="1"/>
                                    </div>
                                    <div class="row">
                                        <label for="htf_webhook_url_whatsapp" class="col-lg-3 o_light_label"/>
                                        <field name="htf_webhook_url_whatsapp" widget="CopyClipboardChar" readonly="1"/>
                                    </div>
                                    <div class="text-muted mt8" style="font-size: 0.9em;">
                                        <p><strong>How to wire these up in Hatif:</strong></p>
                                        <p>1. Open <a href="https://app.hatif.io/en/settings/api-connect" target="_blank">app.hatif.io → Settings → API Connect</a>.</p>
                                        <p>2. For each channel listed there, click Edit on its Post-call Webhook URL field and paste the first URL above.</p>
                                        <p>3. Repeat for that channel's WhatsApp Webhook URL field using the second URL above.</p>
                                        <p>4. Save in Hatif. No restart needed on the Odoo side.</p>
                                        <p class="mt8">Wrong URL? It is computed from web.base.url. Update it in Settings → Technical → Parameters → System Parameters if Odoo is behind a proxy and the auto-detected URL is wrong.</p>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="Webhook signing"
                               name="htf_webhook_block">
                            <setting id="htf_webhook_secrets"
                                     string="HMAC secrets"
                                     help="Each channel on the Hatif side has its own webhookSecret. Paste the current one here; previous stays valid for a 7-day rotation overlap. NOTE (May 2026): Hatif does not yet expose webhookSecret in their portal UI nor send X-Voxa-Signature on deliveries — leave these blank and keep 'Skip webhook HMAC verification' ON in Debug until Hatif enables signing.">
                                <div class="content-group">
                                    <div class="row">
                                        <label for="htf_webhook_secret_current" class="col-lg-3 o_light_label"/>
                                        <field name="htf_webhook_secret_current" password="True"/>
                                    </div>
                                    <div class="row">
                                        <label for="htf_webhook_secret_previous" class="col-lg-3 o_light_label"/>
                                        <field name="htf_webhook_secret_previous" password="True"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="Sync from Hatif"
                               name="htf_sync_block">
                            <setting id="htf_sync_channels"
                                     string="Channels"
                                     help="Pulls every channel in your Hatif workspace into htf.channel. Archived locally (not deleted) when removed remotely.">
                                <div class="content-group">
                                    <div class="row mt8">
                                        <button name="action_sync_channels"
                                                type="object"
                                                string="Sync Channels Now"
                                                class="btn-primary"/>
                                    </div>
                                </div>
                            </setting>
                            <setting id="htf_sync_tags"
                                     string="Tags"
                                     help="Mirrors the Hatif tag registry into htf.tag.">
                                <div class="content-group">
                                    <div class="row mt8">
                                        <button name="action_sync_tags"
                                                type="object"
                                                string="Sync Tags Now"
                                                class="btn-secondary"/>
                                    </div>
                                </div>
                            </setting>
                            <setting id="htf_sync_workspace"
                                     string="Workspace Users"
                                     help="Pulls every workspace user / AI agent into htf.user.link so the Map Users wizard can auto-match them by email.">
                                <div class="content-group">
                                    <div class="row mt8">
                                        <button name="action_sync_workspace_users"
                                                type="object"
                                                string="Sync Workspace Users Now"
                                                class="btn-secondary"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="Polling"
                               name="htf_polling_block">
                            <setting id="htf_polling"
                                     string="Background polling intervals"
                                     help="Contacts and conversations are pulled incrementally on a schedule. Webhooks deliver everything realtime; polling is a safety net + catches updates that have no webhook (contact edits).">
                                <div class="content-group">
                                    <div class="row">
                                        <label for="htf_poll_contacts_interval_min" class="col-lg-6 o_light_label"/>
                                        <field name="htf_poll_contacts_interval_min"/>
                                    </div>
                                    <div class="row">
                                        <label for="htf_poll_conversations_interval_min" class="col-lg-6 o_light_label"/>
                                        <field name="htf_poll_conversations_interval_min"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="WhatsApp UX"
                               name="htf_whatsapp_ux_block">
                            <setting id="htf_whatsapp_ux"
                                     string="WhatsApp button behaviour"
                                     help="Controls what happens when an agent clicks the WhatsApp button on a contact, lead, or phone widget. The recommended Discuss-first UX lets agents read full chat history inline and only forces the template wizard when Meta's 24h reply window is closed.">
                                <div class="content-group">
                                    <div class="row">
                                        <field name="htf_whatsapp_button_opens_discuss"/>
                                        <label for="htf_whatsapp_button_opens_discuss"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="Defaults"
                               name="htf_defaults_block">
                            <setting id="htf_defaults"
                                     string="UX defaults">
                                <div class="content-group">
                                    <div class="row">
                                        <label for="htf_default_voice" class="col-lg-4 o_light_label"/>
                                        <field name="htf_default_voice"/>
                                    </div>
                                    <div class="row">
                                        <label for="htf_timezone_offset_for_filters" class="col-lg-4 o_light_label"/>
                                        <field name="htf_timezone_offset_for_filters"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="Debug"
                               name="htf_debug_block">
                            <setting id="htf_debug"
                                     string="Debug logging"
                                     help="Logs full request/response bodies. Bearer tokens and webhook secrets are stripped by the redaction filter.">
                                <div class="content-group">
                                    <div class="row">
                                        <field name="htf_debug_log_enabled"/>
                                        <label for="htf_debug_log_enabled"/>
                                    </div>
                                    <div class="row">
                                        <field name="htf_dev_mode_skip_hmac"/>
                                        <label for="htf_dev_mode_skip_hmac"/>
                                    </div>
                                </div>
                            </setting>
                        </block>
                    </app>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
