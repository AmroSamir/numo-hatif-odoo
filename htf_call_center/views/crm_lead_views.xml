<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Apply the htf_phone widget on crm.lead.phone + crm.lead.mobile
            so the [Call] + [WhatsApp] buttons render next to lead phones
            the same way they do on res.partner.

            Also adds a header "Send WhatsApp" button alongside the
            standard New Quotation / Won / Enrich / Lost buttons so
            agents have a discoverable entry to the wizard on the form
            where they spend most of their time.

            View id resolved at runtime (Odoo 19 CRM uses an internal
            xmlid; we target by model+type via name="crm_lead_view_form"
            with a soft fallback to crm_case_form_view_oppor).
        -->

        <record id="view_crm_lead_form_inherit_htf" model="ir.ui.view">
            <field name="name">crm.lead.form.inherit.htf</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='phone']" position="attributes">
                    <attribute name="widget">htf_phone</attribute>
                </xpath>
                <!--
                    Expose the related ``x_htf_last_conversation_id``
                    (read-through to ``partner_id.x_htf_last_conversation_id``,
                    declared on crm.lead in ``models/crm_lead.py``) as an
                    invisible field so the OWL record loader pulls it
                    into ``record.data``. The ``htf_phone`` widget's
                    ``hatifCallHref`` getter reads it to deep-link the
                    Call button into the partner's Hatif conversation —
                    matching the Discuss ChatWindow "Call via Hatif"
                    header action behaviour.
                -->
                <xpath expr="//field[@name='phone']" position="after">
                    <field name="x_htf_last_conversation_id" invisible="1"/>
                    <field name="x_htf_last_channel_uuid" invisible="1"/>
                </xpath>
                <xpath expr="//header" position="inside">
                    <!--
                        v19.0.1.35.0: routes through action_htf_open_whatsapp
                        which decides Discuss popup vs classic wizard based
                        on whatsapp_button_opens_discuss param. Falls back to
                        wizard if the lead has no linked partner yet (see
                        crm_lead.action_htf_open_whatsapp).
                    -->
                    <button name="action_htf_open_whatsapp"
                            type="object"
                            string="Send WhatsApp"
                            class="btn-primary"
                            icon="fa-whatsapp"
                            invisible="not phone"
                            groups="htf_call_center.group_user"/>
                </xpath>
            </field>
        </record>

        <!--
            Bind the Send WhatsApp wizard to crm.lead's Action menu so
            it's also reachable from list-view multi-select (e.g. send a
            template to selected leads — bulk path the bridge module will
            promote later).
        -->
        <record id="action_htf_send_whatsapp_wizard_lead_binding"
                model="ir.actions.act_window">
            <field name="name">Send WhatsApp (Lead)</field>
            <field name="res_model">htf.send.whatsapp.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="crm.model_crm_lead"/>
            <field name="binding_view_types">form,list</field>
        </record>

    </data>
</odoo>
