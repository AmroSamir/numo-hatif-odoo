<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_htf_contact_link_list" model="ir.ui.view">
            <field name="name">htf.contact.link.list</field>
            <field name="model">htf.contact.link</field>
            <field name="arch" type="xml">
                <list string="Hatif Contact Links">
                    <field name="partner_id"/>
                    <field name="htf_contact_id"/>
                    <field name="sync_state"/>
                    <field name="last_synced_at"/>
                    <field name="sync_error" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_htf_contact_link_form" model="ir.ui.view">
            <field name="name">htf.contact.link.form</field>
            <field name="model">htf.contact.link</field>
            <field name="arch" type="xml">
                <form string="Hatif Contact Link">
                    <sheet>
                        <group>
                            <group>
                                <field name="partner_id"/>
                                <field name="htf_contact_id"/>
                            </group>
                            <group>
                                <field name="sync_state"/>
                                <field name="last_synced_at"/>
                                <field name="sync_error"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Custom Properties (raw)">
                                <field name="custom_properties_json" widget="ace" options="{'mode': 'json'}"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_htf_contact_link" model="ir.actions.act_window">
            <field name="name">Contact Links</field>
            <field name="res_model">htf.contact.link</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
