<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_htf_tag_list" model="ir.ui.view">
            <field name="name">htf.tag.list</field>
            <field name="model">htf.tag</field>
            <field name="arch" type="xml">
                <list string="Hatif Tags" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="is_pinned"/>
                    <field name="color" widget="color_picker"/>
                    <field name="description" optional="hide"/>
                    <field name="last_synced_at" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_htf_tag_form" model="ir.ui.view">
            <field name="name">htf.tag.form</field>
            <field name="model">htf.tag</field>
            <field name="arch" type="xml">
                <form string="Hatif Tag">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="htf_tag_id"/>
                                <field name="is_pinned"/>
                                <field name="color" widget="color_picker"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="icon"/>
                                <field name="created_at"/>
                                <field name="last_synced_at"/>
                            </group>
                        </group>
                        <field name="description"/>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_htf_tag" model="ir.actions.act_window">
            <field name="name">Tags</field>
            <field name="res_model">htf.tag</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
