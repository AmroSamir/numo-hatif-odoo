<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             htf.template — list view
             ============================================================ -->
        <record id="view_htf_template_list" model="ir.ui.view">
            <field name="name">htf.template.list</field>
            <field name="model">htf.template</field>
            <field name="arch" type="xml">
                <list string="WhatsApp Templates"
                      decoration-success="status == 'approved'"
                      decoration-warning="status == 'pending'"
                      decoration-danger="status in ('rejected','paused')"
                      decoration-muted="status == 'archived' or not active">
                    <field name="name"/>
                    <field name="channel_id"/>
                    <field name="language"/>
                    <field name="category"/>
                    <field name="status"/>
                    <field name="parameter_count" string="# params"/>
                    <field name="active" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- ============================================================
             htf.template — form view
             ============================================================ -->
        <record id="view_htf_template_form" model="ir.ui.view">
            <field name="name">htf.template.form</field>
            <field name="model">htf.template</field>
            <field name="arch" type="xml">
                <form string="WhatsApp Template">
                    <sheet>
                        <widget name="web_ribbon"
                                title="Archived"
                                bg_color="bg-danger"
                                invisible="active"/>
                        <div class="oe_title">
                            <label for="name" string="Template Name"/>
                            <h1>
                                <field name="name"
                                       placeholder="e.g. welcom_message"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Routing">
                                <field name="channel_id"
                                       options="{'no_create': True}"/>
                                <field name="language"/>
                                <field name="category"/>
                            </group>
                            <group string="State">
                                <field name="status"/>
                                <field name="active"/>
                                <field name="parameter_count"/>
                                <field name="parameter_hint"
                                       placeholder="Ahmed|ORD-5123|confirmed"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Body Preview" name="body">
                                <field name="body_preview"
                                       placeholder="Paste a copy of the approved template body here for agent reference. Variables: {{1}}, {{2}}, …"/>
                            </page>
                            <page string="Notes" name="notes">
                                <field name="notes" nolabel="1"
                                       placeholder="Admin notes — e.g. campaign tag, owner, etc."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============================================================
             htf.template — search view
             ============================================================ -->
        <record id="view_htf_template_search" model="ir.ui.view">
            <field name="name">htf.template.search</field>
            <field name="model">htf.template</field>
            <field name="arch" type="xml">
                <search string="Templates">
                    <field name="name"/>
                    <field name="channel_id"/>
                    <field name="language"/>
                    <separator/>
                    <filter name="filter_approved"
                            string="Approved"
                            domain="[('status', '=', 'approved')]"/>
                    <filter name="filter_pending"
                            string="Under Review"
                            domain="[('status', '=', 'pending')]"/>
                    <filter name="filter_archived"
                            string="Archived"
                            domain="[('active', '=', False)]"/>
                    <separator/>
                    <filter name="group_channel"
                            string="Channel"
                            context="{'group_by': 'channel_id'}"/>
                    <filter name="group_status"
                            string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_language"
                            string="Language"
                            context="{'group_by': 'language'}"/>
                </search>
            </field>
        </record>

        <!-- ============================================================
             Action + menu
             ============================================================ -->
        <record id="action_htf_template" model="ir.actions.act_window">
            <field name="name">WhatsApp Templates</field>
            <field name="res_model">htf.template</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_htf_template_search"/>
            <field name="context">{'search_default_filter_approved': 1, 'search_default_group_channel': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Register an approved WhatsApp template</p>
                <p>Mirror your Hatif-approved templates here so agents can pick them from a dropdown in the Send WhatsApp wizard instead of typing the exact name + language by hand. The Meta template name + language MUST match Hatif byte-for-byte or the send will be rejected with a 400.</p>
            </field>
        </record>

    </data>
</odoo>
