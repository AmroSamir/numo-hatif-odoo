<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Override the phone widget on the partner form so it shows the
            [Call] + [WhatsApp] buttons. The base view's phone field uses
            widget="phone" — we swap it to widget="htf_phone" via attributes.

            Also adds a header button "Send WhatsApp" so the wizard is
            discoverable without going through the Action menu (P3 T3.4
            minimum-viable in lieu of a full chatter composer patch —
            see NEXT_SESSION.md for why the full composer is deferred).
        -->
        <record id="view_partner_form_inherit_htf_phone" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.htf.phone</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='phone']" position="attributes">
                    <attribute name="widget">htf_phone</attribute>
                </xpath>
                <!--
                    Expose `x_htf_last_conversation_id` as an invisible
                    field in the form so the HtfPhoneField widget can
                    read it via `record.data.x_htf_last_conversation_id`
                    and deep-link the Call button into the right Hatif
                    conversation. Without this declaration the OWL
                    record loader skips the field and the widget falls
                    back to the Hatif inbox root URL.
                -->
                <xpath expr="//field[@name='phone']" position="after">
                    <field name="x_htf_last_conversation_id" invisible="1"/>
                    <field name="x_htf_last_channel_uuid" invisible="1"/>
                </xpath>
                <!--
                    Header button: visible whenever the partner has a phone,
                    greyed out when window is closed + opt-out is on.
                    The wizard's own preflight banner explains the block.
                -->
                <xpath expr="//sheet" position="before">
                    <header>
                        <!--
                            v19.0.1.35.0: button calls action_htf_open_whatsapp
                            instead of opening the wizard directly. The Python
                            handler decides Discuss popup vs classic wizard
                            based on whatsapp_button_opens_discuss param so
                            the view stays the same for both UXes.
                        -->
                        <button name="action_htf_open_whatsapp"
                                type="object"
                                string="Send WhatsApp"
                                class="btn-primary"
                                icon="fa-whatsapp"
                                invisible="not phone"
                                groups="htf_call_center.group_user"/>
                    </header>
                </xpath>
            </field>
        </record>

        <record id="view_partner_form_inherit_htf" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.htf</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Hatif" name="htf"
                          groups="htf_call_center.group_user">
                        <group>
                            <group string="Identity">
                                <field name="x_htf_contact_id" readonly="1"/>
                                <field name="x_htf_synced_at" readonly="1"/>
                                <field name="x_htf_default_channel_id"
                                       options="{'no_create': True}"/>
                            </group>
                            <group string="Conversation State">
                                <field name="x_htf_last_inbound_at" readonly="1"/>
                                <field name="x_htf_24h_window_open"/>
                                <field name="x_htf_opted_out"/>
                            </group>
                        </group>
                    </page>
                </xpath>
                <!-- Smart buttons for Calls + WA Messages counts (T4.8). -->
                <xpath expr="//div[hasclass('oe_button_box')]"
                       position="inside">
                    <button name="action_view_htf_calls"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-phone"
                            groups="htf_call_center.group_user">
                        <field name="x_htf_call_count"
                               widget="statinfo"
                               string="Calls"/>
                    </button>
                    <button name="action_view_htf_messages"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-whatsapp"
                            groups="htf_call_center.group_user">
                        <field name="x_htf_message_count"
                               widget="statinfo"
                               string="WhatsApp"/>
                    </button>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
