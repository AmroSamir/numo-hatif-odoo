<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             Bind Channels wizard
             ============================================================ -->
        <record id="view_htf_bind_channels_wizard_form" model="ir.ui.view">
            <field name="name">htf.bind.channels.wizard.form</field>
            <field name="model">htf.bind.channels.wizard</field>
            <field name="arch" type="xml">
                <form string="Bind Channels to Teams">
                    <sheet>
                        <p>
                            Assign each Hatif channel to its sales team and pick
                            the per-team defaults. Only one default-WA and one
                            default-call channel per team.
                        </p>
                        <field name="line_ids">
                            <list editable="bottom" create="0" delete="0">
                                <field name="channel_display" readonly="1"/>
                                <field name="channel_type" readonly="1"/>
                                <field name="phone_number" readonly="1"/>
                                <field name="team_id"/>
                                <field name="default_for_outbound_wa"/>
                                <field name="default_for_outbound_call"/>
                            </list>
                        </field>
                    </sheet>
                    <footer>
                        <button name="action_apply" type="object"
                                string="Save" class="btn-primary"/>
                        <button special="cancel" string="Cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_htf_bind_channels_wizard" model="ir.actions.act_window">
            <field name="name">Bind Channels to Teams</field>
            <field name="res_model">htf.bind.channels.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- ============================================================
             Map Users wizard
             ============================================================ -->
        <record id="view_htf_map_users_wizard_form" model="ir.ui.view">
            <field name="name">htf.map.users.wizard.form</field>
            <field name="model">htf.map.users.wizard</field>
            <field name="arch" type="xml">
                <form string="Map Hatif Users to Odoo Users">
                    <sheet>
                        <p>
                            Each Hatif workspace user mapped to its Odoo user.
                            Auto-suggestion is by exact-email match (case-insensitive).
                            Click "Sync from Hatif" first if the list is stale.
                        </p>
                        <button name="action_sync_from_hatif" type="object"
                                string="Sync from Hatif" icon="fa-refresh"/>
                        <field name="line_ids">
                            <list editable="bottom" create="0" delete="0">
                                <!--
                                    link_id is required=True on the line
                                    model. If it isn't in the form view, the
                                    save round-trip drops it and the line
                                    fails its required-field validation.
                                    Render hidden so users don't see it.
                                -->
                                <field name="link_id" column_invisible="1"/>
                                <field name="display_name" readonly="1"/>
                                <field name="email" readonly="1"/>
                                <field name="role" readonly="1"/>
                                <field name="htf_user_id" readonly="1" optional="hide"/>
                                <field name="user_id"/>
                                <field name="channel_ids"
                                       widget="many2many_tags"
                                       options="{'no_create': True}"/>
                            </list>
                        </field>
                    </sheet>
                    <footer>
                        <button name="action_apply" type="object"
                                string="Save" class="btn-primary"/>
                        <button name="action_resuggest" type="object"
                                string="🔄 Re-suggest unmapped"
                                class="btn-secondary"
                                title="Re-run auto-matching for rows with no Odoo user. Already-filled rows are preserved."/>
                        <button special="cancel" string="Cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_htf_map_users_wizard" model="ir.actions.act_window">
            <field name="name">Map Hatif Users</field>
            <field name="res_model">htf.map.users.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- ============================================================
             Import vCards wizard
             ============================================================ -->
        <record id="view_htf_import_vcards_wizard_form" model="ir.ui.view">
            <field name="name">htf.import.vcards.wizard.form</field>
            <field name="model">htf.import.vcards.wizard</field>
            <field name="arch" type="xml">
                <form string="Import vCards into Hatif">
                    <sheet>
                        <group>
                            <field name="file_data" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                        </group>
                        <separator string="…or paste vCards directly:"/>
                        <field name="paste_blob"
                               placeholder="BEGIN:VCARD&#10;…&#10;END:VCARD"
                               widget="text"/>
                        <separator string="Result"/>
                        <field name="result_summary" readonly="1"/>
                        <field name="result_detail" readonly="1"/>
                    </sheet>
                    <footer>
                        <button name="action_import" type="object"
                                string="Import" class="btn-primary"/>
                        <button special="cancel" string="Close" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_htf_import_vcards_wizard" model="ir.actions.act_window">
            <field name="name">Import vCards</field>
            <field name="res_model">htf.import.vcards.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- ============================================================
             Send WhatsApp wizard (P3 T3.5)
             ============================================================ -->
        <record id="view_htf_send_whatsapp_wizard_form" model="ir.ui.view">
            <field name="name">htf.send.whatsapp.wizard.form</field>
            <field name="model">htf.send.whatsapp.wizard</field>
            <field name="arch" type="xml">
                <form string="Send WhatsApp">
                    <sheet>
                        <div class="alert alert-warning" role="alert"
                             invisible="not preflight_error">
                            <field name="preflight_error" readonly="1" nolabel="1"/>
                        </div>
                        <group>
                            <group string="To">
                                <field name="partner_id" readonly="1"/>
                                <field name="to_number"/>
                                <!--
                                    Single, READ-ONLY channel field.
                                    ``channel_id`` is pre-resolved in
                                    default_get via
                                    ``channel_resolver.resolve_outbound_wa``;
                                    the resolver is the source of truth
                                    (team-chain + per-partner / per-lead
                                    override + workspace fallback), so
                                    agents shouldn't be picking a channel
                                    manually from the wizard and risk
                                    sending via a number Hatif hasn't
                                    approved the template on. To change
                                    the channel for a customer, edit the
                                    partner / lead's team binding (or
                                    htf.channel.user_ids override) — the
                                    next time the wizard opens the
                                    resolver will reflect the new mapping.
                                    The legacy ``resolved_channel_display``
                                    helper stays on the model for
                                    downstream code but is no longer
                                    rendered here.
                                -->
                                <field name="channel_id" readonly="1"
                                       force_save="1"/>
                                <field name="dnc_blocked" readonly="1"/>
                                <field name="window_open" readonly="1"/>
                            </group>
                            <group string="Mode">
                                <field name="mode" widget="radio"/>
                            </group>
                        </group>
                        <group invisible="mode != 'text'" string="Free-form text">
                            <field name="text" nolabel="1"
                                   placeholder="Type your message…"/>
                        </group>
                        <group invisible="mode != 'template'" string="Template">
                            <!--
                                template_id is the user-facing pick:
                                domain filters to templates approved on
                                the selected channel (or any channel
                                when the wizard hasn't resolved one
                                yet) AND status=approved. The onchange
                                copies the chosen template's metadata
                                onto the legacy fields below so the API
                                call's request body shape stays the same.
                                Free-form template_name remains editable
                                so admins can still send a template not
                                yet registered in htf.template.
                            -->
                            <field name="template_id"
                                   options="{'no_create': True}"
                                   domain="[('status', '=', 'approved'),
                                            '|',
                                                ('channel_id', '=', channel_id),
                                                ('channel_id.user_ids', '=', uid)]"/>
                            <field name="template_name"
                                   placeholder="exact Hatif-approved template name"/>
                            <field name="template_language"/>
                            <field name="template_category"/>
                            <field name="template_body_params"
                                   placeholder="Ahmed|ORD-5123|confirmed"/>
                            <field name="template_parameters_json"
                                   placeholder='[{"Type":"Body","Values":[...]}]'
                                   widget="text"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_send" type="object"
                                string="Send" class="btn-primary"
                                invisible="preflight_error"/>
                        <button special="cancel" string="Cancel"
                                class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_htf_send_whatsapp_wizard" model="ir.actions.act_window">
            <field name="name">Send WhatsApp</field>
            <field name="res_model">htf.send.whatsapp.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="base.model_res_partner"/>
            <field name="binding_view_types">form,list</field>
        </record>

        <!-- ============================================================
             Server actions for one-click syncs from menus
             ============================================================ -->
        <record id="action_server_sync_channels" model="ir.actions.server">
            <field name="name">Sync Channels from Hatif</field>
            <field name="model_id" ref="model_htf_config"/>
            <field name="state">code</field>
            <field name="code">action = model.action_sync_channels()</field>
        </record>

        <record id="action_server_sync_tags" model="ir.actions.server">
            <field name="name">Sync Tags from Hatif</field>
            <field name="model_id" ref="model_htf_config"/>
            <field name="state">code</field>
            <field name="code">action = model.action_sync_tags()</field>
        </record>

        <record id="action_server_sync_workspace" model="ir.actions.server">
            <field name="name">Sync Workspace Users from Hatif</field>
            <field name="model_id" ref="model_htf_config"/>
            <field name="state">code</field>
            <field name="code">action = model.action_sync_workspace_users()</field>
        </record>

    </data>
</odoo>
