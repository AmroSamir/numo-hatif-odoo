<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Admin-only debug view for htf.message rows. End-users see chatter
         posts on res.partner / crm.lead, not this raw list. -->

    <record id="htf_message_view_list" model="ir.ui.view">
        <field name="name">htf.message.list</field>
        <field name="model">htf.message</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Messages" default_order="created_at desc">
                <field name="created_at"/>
                <field name="direction"/>
                <field name="message_type"/>
                <field name="partner_id"/>
                <field name="channel_id"/>
                <field name="state"/>
                <field name="is_billable" optional="hide"/>
                <field name="htf_message_id" optional="hide"/>
                <field name="is_opt_out" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="htf_message_view_form" model="ir.ui.view">
        <field name="name">htf.message.form</field>
        <field name="model">htf.message</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Message">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Routing">
                            <field name="direction" readonly="1"/>
                            <field name="message_type" readonly="1"/>
                            <field name="channel_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="sender_user_id" readonly="1"/>
                        </group>
                        <group string="Delivery">
                            <field name="state" readonly="1"/>
                            <field name="created_at" readonly="1"/>
                            <field name="delivered_at" readonly="1"/>
                            <field name="read_at" readonly="1"/>
                            <field name="is_billable" readonly="1"/>
                            <field name="is_opt_out" readonly="1"/>
                        </group>
                    </group>
                    <group string="Content">
                        <field name="body" readonly="1" nolabel="1" placeholder="(no body)"/>
                        <field name="media_url" readonly="1" widget="url" optional="show"/>
                        <field name="mime_type" readonly="1"/>
                        <field name="latitude" readonly="1"/>
                        <field name="longitude" readonly="1"/>
                    </group>
                    <group string="Hatif identifiers" col="2">
                        <field name="htf_message_id" readonly="1"/>
                        <field name="conversation_event_id" readonly="1"/>
                        <field name="conversation_uuid" readonly="1"/>
                        <field name="contact_uuid" readonly="1"/>
                    </group>
                    <group string="Errors (if any)" col="2">
                        <field name="error_code" readonly="1"/>
                        <field name="error_reason" readonly="1"/>
                    </group>
                    <group string="Audit">
                        <field name="chatter_message_id" readonly="1"/>
                        <field name="raw_payload" readonly="1" nolabel="1" widget="ace" options="{'mode': 'json'}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="htf_message_view_search" model="ir.ui.view">
        <field name="name">htf.message.search</field>
        <field name="model">htf.message</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="channel_id"/>
                <field name="htf_message_id"/>
                <separator/>
                <filter name="inbound" string="Inbound" domain="[('direction', '=', 'inbound')]"/>
                <filter name="outbound" string="Outbound" domain="[('direction', '=', 'outbound')]"/>
                <separator/>
                <filter name="failed" string="Failed" domain="[('state', '=', 'failed')]"/>
                <filter name="opt_out" string="Opt-out keyword" domain="[('is_opt_out', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="htf_message_action" model="ir.actions.act_window">
        <field name="name">WhatsApp Messages</field>
        <field name="res_model">htf.message</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No WhatsApp messages yet
            </p>
            <p>
                Inbound and outbound WhatsApp messages will appear here.
                End-users normally read messages on the related contact's
                chatter — this view is for debugging.
            </p>
        </field>
    </record>
</odoo>
