<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_htf_webhook_event_list" model="ir.ui.view">
            <field name="name">htf.webhook.event.list</field>
            <field name="model">htf.webhook.event</field>
            <field name="arch" type="xml">
                <list string="Webhook events" default_order="received_at desc">
                    <field name="received_at"/>
                    <field name="route"/>
                    <field name="event_id"/>
                    <field name="processed"/>
                    <field name="note"/>
                    <field name="payload_hash" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_htf_webhook_event_form" model="ir.ui.view">
            <field name="name">htf.webhook.event.form</field>
            <field name="model">htf.webhook.event</field>
            <field name="arch" type="xml">
                <form string="Webhook event">
                    <sheet>
                        <group>
                            <group>
                                <field name="route"/>
                                <field name="event_id"/>
                                <field name="received_at"/>
                                <field name="processed"/>
                            </group>
                            <group>
                                <field name="payload_hash"/>
                                <field name="note"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_htf_webhook_event_search" model="ir.ui.view">
            <field name="name">htf.webhook.event.search</field>
            <field name="model">htf.webhook.event</field>
            <field name="arch" type="xml">
                <search>
                    <field name="event_id"/>
                    <field name="route"/>
                    <filter name="processed" string="Processed"
                            domain="[('processed', '=', True)]"/>
                    <filter name="unprocessed" string="Unprocessed"
                            domain="[('processed', '=', False)]"/>
                    <separator/>
                    <filter name="group_route" string="Route"
                            context="{'group_by': 'route'}"/>
                </search>
            </field>
        </record>

        <record id="action_htf_webhook_event" model="ir.actions.act_window">
            <field name="name">Webhook events</field>
            <field name="res_model">htf.webhook.event</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_htf_webhook_event_search"/>
        </record>

    </data>
</odoo>
