<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Admin debug view for htf.call rows. End-users see chatter
        posts on res.partner / crm.lead, not this raw list.
        create='0' — calls come from Hatif, never manual creation.
    -->

    <record id="htf_call_view_list" model="ir.ui.view">
        <field name="name">htf.call.list</field>
        <field name="model">htf.call</field>
        <field name="arch" type="xml">
            <list string="Calls" default_order="created_at desc" create="0">
                <field name="created_at"/>
                <field name="direction"/>
                <field name="status"/>
                <field name="partner_id"/>
                <field name="channel_id"/>
                <field name="handler_user_id"/>
                <field name="duration_display" string="Duration"/>
                <field name="duration_seconds" optional="hide" string="Duration (s)"/>
                <field name="sentiment" optional="show"/>
                <field name="recording_url" optional="hide"/>
                <field name="htf_call_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="htf_call_view_form" model="ir.ui.view">
        <field name="name">htf.call.form</field>
        <field name="model">htf.call</field>
        <field name="arch" type="xml">
            <form string="Call" create="0">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Routing">
                            <field name="direction" readonly="1"/>
                            <field name="status" readonly="1"/>
                            <field name="channel_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="handler_user_id" readonly="1"/>
                            <field name="hatif_user_name" readonly="1"
                                   invisible="handler_user_id"/>
                            <field name="ai_agent_uuid" readonly="1"
                                   invisible="not ai_agent_uuid"/>
                        </group>
                        <group string="Timing">
                            <field name="created_at" readonly="1"/>
                            <field name="pickup_time" readonly="1"/>
                            <field name="hangup_time" readonly="1"/>
                            <!--
                                duration_seconds is a plain int (number of
                                seconds). DO NOT use widget='float_time' —
                                that treats the value as hours-and-fraction
                                (so 32s renders as '32:00' = 32 hours). The
                                duration_display computed Char gives the
                                human-readable '5:32' / '1:05:32' form.
                            -->
                            <field name="duration_display" readonly="1"
                                   string="Duration"/>
                            <field name="duration_seconds" readonly="1"
                                   string="Duration (s)" optional="hide"/>
                            <field name="call_length_raw" readonly="1"
                                   invisible="not call_length_raw"
                                   optional="hide"/>
                        </group>
                    </group>
                    <group>
                        <group string="Phones">
                            <field name="caller_number" readonly="1"/>
                            <field name="callee_number" readonly="1"/>
                            <field name="contact_number" readonly="1"
                                   invisible="not contact_number"/>
                        </group>
                        <group string="Analytics">
                            <field name="sentiment" readonly="1"/>
                            <field name="recording_url" readonly="1"
                                   widget="url"/>
                            <field name="is_ai_call" readonly="1"/>
                            <field name="csat_rating" readonly="1"
                                   invisible="not csat_rating"/>
                            <field name="csat_method" readonly="1"
                                   invisible="not csat_method"/>
                            <field name="csat_collected_at" readonly="1"
                                   invisible="not csat_collected_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Summary"
                              invisible="not summary">
                            <field name="summary" readonly="1" nolabel="1"/>
                        </page>
                        <page string="Transcript"
                              invisible="not transcription_text">
                            <field name="transcription_text" readonly="1"
                                   nolabel="1"/>
                            <separator string="Word-level (JSON)"/>
                            <field name="transcription_words_json"
                                   readonly="1" nolabel="1" widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                        <page string="QA Rubric"
                              invisible="not evaluation_criteria_json">
                            <field name="evaluation_criteria_json"
                                   readonly="1" nolabel="1" widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                        <page string="Hatif identifiers">
                            <group>
                                <field name="htf_call_id" readonly="1"/>
                                <field name="workspace_uuid" readonly="1"/>
                                <field name="contact_uuid" readonly="1"/>
                            </group>
                        </page>
                        <page string="Audit">
                            <field name="chatter_message_id" readonly="1"/>
                            <field name="raw_payload" readonly="1"
                                   nolabel="1" widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="htf_call_view_search" model="ir.ui.view">
        <field name="name">htf.call.search</field>
        <field name="model">htf.call</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="channel_id"/>
                <field name="handler_user_id"/>
                <field name="htf_call_id"/>
                <separator/>
                <filter name="inbound" string="Inbound"
                        domain="[('direction', '=', 'inbound')]"/>
                <filter name="outbound" string="Outbound"
                        domain="[('direction', '=', 'outbound')]"/>
                <separator/>
                <filter name="completed" string="Completed"
                        domain="[('status', '=', 'completed')]"/>
                <filter name="missed" string="Missed (any kind)"
                        domain="[('status', 'in',
                            ['missed','no_answer','rejected_by_callee','cancelled'])]"/>
                <filter name="failed" string="Failed"
                        domain="[('status', '=', 'failed')]"/>
                <separator/>
                <filter name="has_recording" string="Has Recording"
                        domain="[('recording_url', '!=', False)]"/>
                <filter name="has_transcript" string="Has Transcript"
                        domain="[('transcription_text', '!=', False)]"/>
            </search>
        </field>
    </record>

    <record id="htf_call_action" model="ir.actions.act_window">
        <field name="name">Calls</field>
        <field name="res_model">htf.call</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="htf_call_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No calls yet
            </p>
            <p>
                Calls flow in automatically when Hatif posts to the
                <b>Post-call Webhook URL</b> configured per channel at
                <code>app.hatif.io/en/settings/api-connect</code>.
            </p>
            <p>
                Set each channel's Post-call URL to
                <code>https://&lt;your-host&gt;/htf/webhook/call</code>
                and place a test call to see rows here.
            </p>
        </field>
    </record>
</odoo>
