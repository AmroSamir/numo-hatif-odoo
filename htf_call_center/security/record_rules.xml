<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
            Baseline record rules for P0. Each later phase that ships a new
            user-facing model adds its own rules (typically scoped to handler_user
            or partner.user_id) here via inheritance / new <record>.
        -->

        <record id="rule_htf_webhook_event_admin_all" model="ir.rule">
            <field name="name">htf.webhook.event: admin sees all</field>
            <field name="model_id" ref="model_htf_webhook_event"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('htf_call_center.group_admin'))]"/>
        </record>

        <record id="rule_htf_webhook_event_user_none" model="ir.rule">
            <field name="name">htf.webhook.event: standard users see none</field>
            <field name="model_id" ref="model_htf_webhook_event"/>
            <field name="domain_force">[(0, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('htf_call_center.group_user'))]"/>
        </record>

    </data>
</odoo>
