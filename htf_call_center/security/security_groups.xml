<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Odoo 19 removed res.groups.category_id and res.groups.comment.
        Group categorization is now handled via res.groups.privilege_id (new
        in 18/19) or by naming convention. We keep the naming convention
        ("Hatif: User" / "Hatif: Administrator") so the groups stay grouped
        in the access-rights UI without needing a custom category.
    -->

    <record id="group_user" model="res.groups">
        <field name="name">Hatif: User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_admin" model="res.groups">
        <field name="name">Hatif: Administrator</field>
        <field name="implied_ids" eval="[(4, ref('htf_call_center.group_user'))]"/>
        <!--
            Directly seed the two built-in admin users into this group.
            `base.group_system.implied_ids` would also work for FRESH
            installs, but adding an implication to an existing group does
            NOT retroactively grant it to current members — Odoo only
            propagates at assign-time. So we set `user_ids` here as the
            hard guarantee.

            Odoo 19 renamed res.groups.users → user_ids (and
            res.users.groups_id → group_ids). Using the old name silently
            failed in earlier installs of this module.
        -->
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
