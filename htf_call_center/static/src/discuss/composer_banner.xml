<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <!--
        v19.0.1.35.0 — composer template extensions for the
        Discuss-first WhatsApp UX.

        Two injections, both gated on the patched ``htfIsWindowClosed``
        getter (composer_patch.js) which reads ``thread.windowOpen``:

          1. Warning banner above the input pocket with a prominent
             teal "Send Template" call-to-action button.
          2. ``o-htf-composer-pocket-disabled`` class on the input
             container so CSS can grey the textarea + block clicks.

        When the customer replies, OWL re-renders the composer,
        htfIsWindowClosed becomes false, and both extensions
        disappear without manual refresh.

        Banner text is translated via ar.po — only ONE source string
        per message (no duplicated hardcoded Arabic line) so an Arabic
        locale shows the Arabic translation and any other locale
        shows the English msgid.
    -->
    <t t-name="htf_call_center.ComposerExtensions"
       t-inherit="mail.Composer"
       t-inherit-mode="extension">
        <!--
            Banner inserted just above the main composer row (which
            holds the textarea and the action toolbar). Banner is a
            single warning alert with an inline call-to-action.
        -->
        <xpath expr="//div[hasclass('o-mail-Composer-coreMain')]" position="before">
            <div t-if="htfIsWindowClosed"
                 class="o-htf-window-closed-banner alert alert-warning d-flex align-items-center justify-content-between mx-2 my-2 py-2 px-3"
                 role="status">
                <div class="d-flex align-items-center flex-grow-1">
                    <i class="fa fa-clock-o me-2 flex-shrink-0"/>
                    <div class="small flex-grow-1">
                        <span t-out="htfBannerLabel"/>
                    </div>
                </div>
                <button type="button"
                        class="o-htf-send-template btn btn-sm ms-2 flex-shrink-0"
                        t-on-click="onClickHtfSendTemplate">
                    <i class="fa fa-file-text-o me-1"/>
                    <span t-out="htfSendTemplateLabel"/>
                </button>
            </div>
        </xpath>
        <!--
            Conditional class on the input container so descendant
            CSS can grey-out the textarea + block pointer events.
        -->
        <xpath expr="//div[hasclass('o-mail-Composer-inputContainer')]" position="attributes">
            <attribute name="t-att-class">htfIsWindowClosed ? 'o-htf-composer-pocket-disabled' : ''</attribute>
        </xpath>
    </t>
</templates>
