<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        P7.5 — ChatWindow header injection: "Call via Hatif" anchor.

        For Hatif-linked threads (x_htf_partner_id present) the
        thread_model_patch.js sets `allowCalls=false` so every native
        voice/video icon is hidden by the upstream ActionList. We
        inject this button BEFORE the ActionList so it occupies the
        same spot the native call icon would have.

        For non-Hatif threads `hatifCallHref` is false and the t-if
        keeps the button out of the DOM. Standard colleague chats are
        therefore unaffected.

        target="_blank" + rel="noopener" so the user's Odoo session
        is preserved and Hatif tab can't postMessage back to it.
    -->
    <t t-inherit="mail.ChatWindow" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-ChatWindow-header')]//div[hasclass('d-flex') and hasclass('flex-shrink-0') and hasclass('me-1')]" position="before">
            <a t-if="thread and thread.hatifCallHref"
               t-att-href="thread.hatifCallHref"
               target="_blank"
               rel="noopener"
               class="o-mail-ChatWindow-hatif-call btn btn-sm d-flex align-items-center text-success me-1"
               title="Call via Hatif (opens Hatif portal in a new tab)">
                <i class="fa fa-phone"/>
                <span class="ms-1 d-none d-md-inline">Call via Hatif</span>
            </a>
        </xpath>
    </t>

</templates>
