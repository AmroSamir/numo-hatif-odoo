<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="htf_call_center.HtfPhoneField">
        <div class="o_phone_content d-inline-flex align-items-center w-100">
            <t t-if="props.readonly">
                <a t-if="hasPhoneValue"
                   class="o_form_uri"
                   target="_blank"
                   t-att-href="phoneHref"
                   t-esc="props.record.data[props.name]"/>
            </t>
            <t t-else="">
                <input
                    class="o_input"
                    t-att-id="props.id"
                    type="tel"
                    autocomplete="off"
                    t-att-placeholder="props.placeholder"
                    t-ref="input"
                />
            </t>

            <!-- Call button — same tel: deep-link as the standard widget -->
            <a t-if="hasPhoneValue"
               t-att-href="phoneHref"
               target="_blank"
               class="o_htf_phone_btn o_phone_form_link ms-2 d-inline-flex align-items-center"
               title="اتصال (يفتح تطبيق الهاتف / Hatif)">
                <i class="fa fa-phone"/>
                <small class="fw-bold ms-1">اتصال</small>
            </a>

            <!-- WhatsApp button — opens Send WA wizard if partner context exists -->
            <a t-if="hasPhoneValue and partnerId"
               href="#"
               t-on-click="onWhatsAppClick"
               class="o_htf_wa_btn ms-2 d-inline-flex align-items-center"
               title="إرسال رسالة واتساب">
                <i class="fa fa-whatsapp text-success"/>
                <small class="fw-bold ms-1 text-success">واتساب</small>
            </a>
        </div>
    </t>

</templates>
