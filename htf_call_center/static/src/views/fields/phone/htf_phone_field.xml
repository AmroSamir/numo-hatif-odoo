<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="htf_call_center.HtfPhoneField">
        <div class="o_phone_content d-inline-flex align-items-center w-100">
            <t t-if="props.readonly">
                <a t-if="hasPhoneValue"
                   class="o_form_uri"
                   target="_blank"
                   rel="noopener noreferrer"
                   t-att-href="hatifCallHref"
                   t-esc="props.record.data[props.name]"/>
            </t>
            <t t-else="">
                <input
                    class="o_input"
                    t-att-id="props.id"
                    type="tel"
                    autocomplete="off"
                    t-att-placeholder="props.placeholder"
                    t-ref="input"
                />
            </t>

            <!--
                Call button — opens Hatif portal in a new tab.
                Replaces the standard widget's tel: deep-link, which on
                desktop hands off to the OS protocol handler (Facetime /
                Skype) and bypasses Hatif entirely. Hatif portal has the
                softphone + conversation history the agent actually needs.
            -->
            <a t-if="hasPhoneValue"
               t-att-href="hatifCallHref"
               target="_blank"
               rel="noopener noreferrer"
               class="o_htf_phone_btn ms-2 d-inline-flex align-items-center"
               title="Call via Hatif (opens Hatif portal in a new tab)">
                <i class="fa fa-phone"/>
                <small class="fw-bold ms-1">Call via Hatif</small>
            </a>

            <!-- WhatsApp button — opens Send WA wizard if partner context exists -->
            <a t-if="hasPhoneValue and partnerId"
               href="#"
               t-on-click="onWhatsAppClick"
               class="o_htf_wa_btn ms-2 d-inline-flex align-items-center"
               title="Send WhatsApp message">
                <i class="fa fa-whatsapp text-success"/>
                <small class="fw-bold ms-1 text-success">WhatsApp</small>
            </a>
        </div>
    </t>

</templates>
